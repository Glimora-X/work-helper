# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Deploy BFF (server/deploy-api.ts, started via npm run dev:api or npm run dev) ---
# Port for the small Express API that talks to Jenkins/Jira (never expose tokens to the browser).
DEPLOY_API_PORT=55532

# Jenkins: base URL (no trailing slash), user + API token. Used server-side only.
JENKINS_URL="https://jenkins.example.com"
JENKINS_USER="jenkins-user"
JENKINS_TOKEN="jenkins-api-token"

# Optional: query parameter names on buildWithParameters (must match your Job config).
JENKINS_PARAM_JIRA="JIRA_ID"
JENKINS_PARAM_BRANCH="BRANCH"

# Jira Cloud / Server: site base URL, email + API token (Cloud) or PAT. Used server-side only.
JIRA_BASE_URL="https://your-domain.atlassian.net"
JIRA_EMAIL="you@company.com"
JIRA_API_TOKEN="jira-api-token"

# Optional: REST path under JIRA_BASE_URL (default rest/api/3 for Jira Cloud).
# JIRA_REST_PATH_PREFIX="rest/api/3"

# JSON map: Jira component name (case-insensitive) -> Jenkins job path as slash-separated segments.
# Example: { "Frontend": ["webapp", "cc-web"], "Platform": ["infra", "deploy", "all"] }
JIRA_COMPONENT_JOB_MAP="{\"Frontend\":[\"cc-web\"],\"Backend\":[\"biz-core\"]}"

# Comma-separated job path strings when Jira is unavailable or has no matching components.
JIRA_RESOLUTION_FALLBACK_NODES="biz-core,cc-web"

# Optional: override deploy API URL from the browser (default same-origin /api/deploy with Vite proxy).
# VITE_DEPLOY_API_BASE="http://127.0.0.1:8787/api/deploy"
