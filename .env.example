# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Deploy BFF (server/deploy-api.ts, started via npm run dev:api or npm run dev) ---
# Port for the small Express API that talks to Jenkins/Jira (never expose tokens to the browser).
# 默认与代码内一致为 8787；若端口被占用，deploy-api 会另选端口并写入项目根 .deploy-api-port，Vite 代理会跟读该文件。
DEPLOY_API_PORT=8788

# Jenkins: user + API token. Used server-side only.
# Jenkins job URLs are mapped per project in config/deploy-projects.json.
# Missing credentials make /api/deploy/jenkins/trigger return 503.
JENKINS_USER="jenkins-user"
JENKINS_TOKEN="jenkins-api-token"

# Optional: deploy project config path. Defaults to config/deploy-projects.json.
# DEPLOY_PROJECT_CONFIG_PATH="./config/deploy-projects.json"

# Jira（总结页、部署 Jira 解析、与 MCP 同一套；勿入库）。JENKINS_* 不能代替 Jira 登录名（未设 JIRA_USERNAME 时偶尔可作登录名兜底）。
# 勿写成 JSON 行尾逗号（错误示例：https://…/", ），否则请求 URL 会非法。
# JIRA_SERVER_URL="https://jira.example.com/"
# JIRA_USERNAME="your.loginId"
# 密钥二选一：登录密码 / PAT，或 REST API Token（与用户名组成 Basic）
# JIRA_PASSWORD="your-password-or-pat"
# JIRA_API_TOKEN="your-rest-api-token"
#
# Optional: REST 前缀（默认 rest/api/3）。公司自建 Jira Server/DC 多为 rest/api/2；未配置时接口会对 404 自动重试 api/2 一次。
# JIRA_REST_PATH_PREFIX="rest/api/2"

# JSON map: Jira component name (case-insensitive) -> Jenkins job path as slash-separated segments.
# Example: { "Frontend": ["webapp", "cc-web"], "Platform": ["infra", "deploy", "all"] }
JIRA_COMPONENT_JOB_MAP="{\"Frontend\":[\"cc-web\"],\"Backend\":[\"biz-core\"]}"

# Comma-separated job path strings when Jira is unavailable or has no matching components.
JIRA_RESOLUTION_FALLBACK_NODES="biz-core,cc-web"

# 若 shell 长期 export ELECTRON=1，旧版 Vite 会误关 /api 代理；现已改为仅认 VITE_DISABLE_DEPLOY_PROXY=1。仍异常时请重启 dev 后再试。
# 前端直连 deploy-api 时才需要（默认留空：走 Vite 同源 /api/* 代理，端口随 .deploy-api-port 自动对齐）。
# 若设置，则「主机:端口」必须与正在运行的 deploy-api 一致，否则 /api/jira/status 会得到 HTML 错误页（<!DOCTYPE...）。
# VITE_DEPLOY_API_BASE="http://127.0.0.1:8787/api/deploy"
