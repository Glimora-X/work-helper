# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Deploy BFF (server/deploy-api.ts, started via npm run dev:api or npm run dev) ---
# Port for the small Express API that talks to Jenkins/Jira (never expose tokens to the browser).
# 默认与代码内一致为 8787；若端口被占用，deploy-api 会另选端口并写入项目根 .deploy-api-port，Vite 代理会跟读该文件。
DEPLOY_API_PORT=8788

# Jenkins: user + API token. Used server-side only.
# Jenkins job URLs are mapped per project in config/deploy-projects.json.
# Missing credentials make /api/deploy/jenkins/trigger return 503.
JENKINS_USER="jenkins-user"
JENKINS_TOKEN="jenkins-api-token"

# Optional: deploy project config path. Defaults to config/deploy-projects.json.
# DEPLOY_PROJECT_CONFIG_PATH="./config/deploy-projects.json"

# 可选：deploy-api 加载的 .env 绝对路径（桌面包默认读不到开发机「项目根/.env」时，用此项指向你的文件）。
# DEPLOY_API_DOTENV="/绝对路径/.env"
#
# Jira（总结页、部署 Jira 解析、与 MCP 同一套；勿入库）。JENKINS_* 不能代替 Jira 登录名（未设 JIRA_USERNAME 时偶尔可作登录名兜底）。
# 勿写成 JSON 行尾逗号（错误示例：https://…/", ），否则请求 URL 会非法。
# JIRA_SERVER_URL="https://jira.example.com/"
# JIRA_USERNAME="your.loginId"
# 密钥二选一：登录密码 / PAT，或 REST API Token（与用户名组成 Basic）
# JIRA_PASSWORD="your-password-or-pat"
# JIRA_API_TOKEN="your-rest-api-token"
#
# Optional: REST 前缀（默认 rest/api/3）。公司自建 Jira Server/DC 多为 rest/api/2；未配置时接口会对 404 自动重试 api/2 一次。
# JIRA_REST_PATH_PREFIX="rest/api/2"

# JSON map: Jira component name (case-insensitive) -> Jenkins job path as slash-separated segments.
# Example: { "Frontend": ["webapp", "cc-web"], "Platform": ["infra", "deploy", "all"] }
JIRA_COMPONENT_JOB_MAP="{\"Frontend\":[\"cc-web\"],\"Backend\":[\"biz-core\"]}"

# Comma-separated job path strings when Jira is unavailable or has no matching components.
JIRA_RESOLUTION_FALLBACK_NODES="biz-core,cc-web"

# 若 shell 长期 export ELECTRON=1，旧版 Vite 会误关 /api 代理；现已改为仅认 VITE_DISABLE_DEPLOY_PROXY=1。仍异常时请重启 dev 后再试。
# 前端直连 deploy-api 时才需要（默认留空：走 Vite 同源 /api/* 代理，端口随 .deploy-api-port 自动对齐）。
# 若设置，则「主机:端口」必须与正在运行的 deploy-api 一致，否则 /api/jira/status 会得到 HTML 错误页（<!DOCTYPE...）。
# VITE_DEPLOY_API_BASE="http://127.0.0.1:8787/api/deploy"

# --- Artistic 助手（/artistic，server/deploy-api）---
# 知识库：逗号分隔的本地目录（递归检索 .md/.mdx/.txt）；可与下方 Wiki 模板同时使用。
# ASSISTANT_KB_LOCAL_DIRS="/path/to/docs,/another/wiki-export"
#
# Wiki 全文检索（两种常见接法，可并存）
# （1）Wiki 搭在 Atlassian Confluence 上：直连全文（CQL），变量名沿用 Atlassian 习惯写 CONFLUENCE_*
# CONFLUENCE_BASE_URL="https://your-site.atlassian.net/wiki"
# 或 Server/DC：CONFLUENCE_BASE_URL="https://confluence.example.com"
# 账号与 Jira 同源时可只配 JIRA_USERNAME + JIRA_API_TOKEN；也可单独写：
# CONFLUENCE_USERNAME=""
# CONFLUENCE_API_TOKEN=""
# CONFLUENCE_PASSWORD=""
#
# （2）其它知识库（语雀、自建 Wiki、CDN 上的搜索聚合等）：每条一个「全文搜索」GET 地址模板（支持 {{query}}）。
# 多路用英文分号 ; 分隔，与下方「单路」变量会合并、自动去重。
# ASSISTANT_KB_SEARCH_URLS="https://yuque-bridge.example/search?q={{query}};https://cdn.example.com/kb-index?q={{query}}"
# 兼容旧名（仅一条时二选一即可）：
# ASSISTANT_WIKI_SEARCH_URL_TEMPLATE="https://your-bridge.example/search?text={{query}}"
# 云端 Gemini（可选）
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
#
# GPT（OpenAI Chat Completions，可选；Dottie-Assistant页「GPT · …」）
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# 可选代理 / 兼容端点（须含 /v1，末尾勿加 /chat/completions）
# OPENAI_BASE_URL="https://api.openai.com/v1"
# Ollama HTTP 基址（默认 http://127.0.0.1:11434）
# OLLAMA_HOST="http://127.0.0.1:11434"

# --- 阿里企业邮箱 Digest（总结页邮件摘要，server/deploy-api IMAP）---
# 需在阿里邮箱网页版开启「三方客户端安全密码」，用该密码代替登录密码。
# MAIL_IMAP_USER="wangjuan3@chanjet.com"
# MAIL_IMAP_PASSWORD="your-client-security-password"
# MAIL_IMAP_HOST="imap.qiye.aliyun.com"
# MAIL_IMAP_PORT="993"
# MAIL_DIGEST_SCHEDULE="08:00"
# MAIL_DIGEST_LOOKBACK_HOURS="24"
# MAIL_DIGEST_ENABLED="true"
# 订阅规则见 config/mail-subscriptions.json
