{
  "color": {
    "canvas": {
      "$value": "hsl(273, 37%, 93%)",
      "$type": "color",
      "$description": "文档主背景（浅色），来自 pkmer theme.css --theme-bg"
    },
    "canvas-gradient-end": {
      "$value": "#fdfeff",
      "$type": "color",
      "$description": "垂直渐变底部高光，接近纯白，柔化长文阅读疲劳"
    },
    "ink": {
      "$value": "hsl(250, 14%, 10%)",
      "$type": "color",
      "$description": "正文主色，对应 --theme-text（灰阶 hsla 灰板 10%）"
    },
    "ink-light": {
      "$value": "hsl(250, 14%, 30%)",
      "$type": "color",
      "$description": "次级正文 / 说明，--theme-text-light"
    },
    "accent": {
      "$value": "hsl(22, 100%, 50%)",
      "$type": "color",
      "$description": "主题强调色（橙），链接与选中态，--theme-accent"
    },
    "accent-secondary": {
      "$value": "hsl(324, 75%, 38%)",
      "$type": "color",
      "$description": "次要强调（洋红紫），--theme-accent-secondary"
    },
    "code-bg": {
      "$value": "hsl(257, 31%, 22%)",
      "$type": "color",
      "$description": "代码块背景，--theme-code-bg"
    },
    "code-text": {
      "$value": "hsl(250, 14%, 95%)",
      "$type": "color",
      "$description": "代码块前景，--theme-code-text"
    },
    "mark-light": {
      "$value": "#ffff8fd1",
      "$type": "color",
      "$description": "浅色模式下正文 mark 高亮底（与 Highlightr 导出语义一致）"
    },
    "mark-dark": {
      "$value": "#e95f44cc",
      "$type": "color",
      "$description": "深色模式下 mark 高亮底，--theme-dark mark"
    },
    "primary-600": {
      "$value": "#4f46e5",
      "$type": "color",
      "$description": "导航品牌交互主色（Tailwind primary-600 编译值）"
    },
    "muted-800": {
      "$value": "#1e293b",
      "$type": "color",
      "$description": "浅色外壳上的深标题/图标对比色（muted-800）"
    },
    "shell-bg": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "顶栏与卡片默认白底"
    },
    "canvas-dark": {
      "$value": "rgb(10, 16, 31)",
      "$type": "color",
      "$description": "深色文档画布 --theme-bg（.theme-dark）"
    }
  },
  "font": {
    "body": {
      "$value": "system-ui",
      "$type": "fontFamily",
      "$description": "正文与 UI，--font-body 栈首项"
    },
    "mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "等宽代码，--font-mono"
    }
  },
  "dimension": {
    "navbar-height": {
      "$value": "4rem",
      "$type": "dimension",
      "$description": "顶栏高度 --theme-navbar-height"
    },
    "sidebar-left": {
      "$value": "18rem",
      "$type": "dimension",
      "$description": "左侧文档导航宽度 --theme-left-sidebar-width"
    },
    "sidebar-right": {
      "$value": "23rem",
      "$type": "dimension",
      "$description": "右侧栏宽度 --theme-right-sidebar-width"
    }
  },
  "typography": {
    "doc-base": {
      "$value": {
        "fontFamily": "system-ui, sans-serif",
        "fontSize": "1rem",
        "lineHeight": "1.5"
      },
      "$type": "typography",
      "$description": "文档正文基准 --theme-text-base"
    },
    "doc-sm": {
      "$value": {
        "fontFamily": "system-ui, sans-serif",
        "fontSize": "0.9375rem",
        "lineHeight": "1.5"
      },
      "$type": "typography",
      "$description": "紧凑辅助文案 --theme-text-sm"
    }
  },
  "shadow": {
    "nav-elevated": {
      "$value": "0 10px 15px -3px rgba(148, 163, 184, 0.3), 0 4px 6px -4px rgba(148, 163, 184, 0.3)",
      "$type": "shadow",
      "$description": "导航滚动后浅阴影（对应 shadow-lg + muted/30）"
    },
    "megamenu": {
      "$value": "0 25px 50px -12px rgba(100, 116, 139, 0.2)",
      "$type": "shadow",
      "$description": "巨型下拉卡片（shadow-2xl + muted-500/20）"
    }
  },
  "radius": {
    "panel": {
      "$value": "1rem",
      "$type": "borderRadius",
      "$description": "rounded-2xl 卡片/菜单容器"
    },
    "mark": {
      "$value": "0.6em 0.3em",
      "$type": "borderRadius",
      "$description": "mark 不规则圆角（theme.css border-radius）"
    }
  }
}
