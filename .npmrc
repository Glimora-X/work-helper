# lightningcss / @tailwindcss/oxide 会声明多平台 optionalDependencies；
# 部分企业镜像未同步 android、freebsd 等包时，yarn/npm 会报「找不到包」。
# 本仓库依赖均为公开包，默认走官方 registry；若你有私有包，请改用 .npmrc 里按 scope 拆分 registry。
registry=https://registry.npmjs.org/
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_cache=~/.cache/electron
